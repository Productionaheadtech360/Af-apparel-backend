# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=production
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL_SYNC=postgresql://user:password@host:5432/dbname

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Security ──────────────────────────────────────────────────────────────────
APP_SECRET_KEY=your-secret-key-here-min-32-chars
JWT_SECRET_KEY=your-jwt-secret-key-here-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Cookie (cross-domain: Railway backend + Vercel frontend) ──────────────────
# Set these when frontend (Vercel) and backend (Railway) are on different domains
COOKIE_SECURE=true
COOKIE_SAMESITE=none
COOKIE_DOMAIN=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (Vercel wildcard handled automatically)
ALLOWED_ORIGINS=https://your-app.vercel.app

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app

# ── QuickBooks ────────────────────────────────────────────────────────────────
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=https://your-backend.railway.app/api/v1/admin/quickbooks/callback
QB_ENVIRONMENT=production
QB_COMPANY_ID=
QB_ACCESS_TOKEN=
QB_REFRESH_TOKEN=

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
EMAIL_FROM_NAME=AF Apparels
ADMIN_NOTIFICATION_EMAIL=admin@yourdomain.com

# ── AWS S3 (optional — for media uploads) ────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=afapparel-media
AWS_S3_REGION=us-east-1
CDN_BASE_URL=

# ── reCAPTCHA ─────────────────────────────────────────────────────────────────
RECAPTCHA_SECRET_KEY=

# ── Sentry (optional) ────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
